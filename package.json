{
  "name": "chatterbox3000",
  "type": "module",
  "workspaces": [
    "worker",
    "extension",
    "docs"
  ],
  "repository": "https://github.com/AppulseSoftware/chatterbox3000",
  "author": "Appulse Software B.V.",
  "license": "MIT",
  "homepage": "https://chatterbox3000.com",
  "bugs": "https://github.com/AppulseSoftware/chatterbox3000/issues",
  "keywords": [
    "email",
    "filter",
    "approval",
    "system",
    "cloudflare",
    "workers",
    "d1",
    "durable objects",
    "websocket",
    "chrome extension"
  ],
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run dev:worker & bun run dev:extension & bun run dev:docs & wait",
    "dev:worker": "bun run --cwd worker dev",
    "dev:extension": "bun run --cwd extension dev",
    "dev:docs": "bun run --cwd docs dev",
    "build": "bun run build:worker & bun run build:extension & bun run build:docs & wait",
    "build:worker": "bun run --cwd worker deploy",
    "build:extension": "bun run --cwd extension build",
    "build:docs": "bun run --cwd docs build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "wrangler": "^4.81.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
